{
  "name": "mcp-konduct",
  "version": "1.6.11",
  "description": "MCP server proxy/aggregator for managing multiple downstream MCP servers",
  "type": "module",
  "bin": {
    "mcp-konduct": "./dist/cli/index.js",
    "konduct": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build:client": "cd src/web/client && npm run build",
    "build:server": "tsc",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist/cli/index.js",
    "test": "vitest"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "proxy",
    "aggregator"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "hono": "^4.12.9",
    "htmx.org": "^2.0.8",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "4.1.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
