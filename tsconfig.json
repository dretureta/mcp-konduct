{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "config/*": ["./src/config/*"],
      "core/*": ["./src/core/*"],
      "cli/*": ["./src/cli/*"],
      "transports/*": ["./src/transports/*"],
      "types/*": ["./src/types/*"]
    }
  },
  "include": ["src/**/*"]
}
